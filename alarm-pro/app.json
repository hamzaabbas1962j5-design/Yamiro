{
  "expo": {
    "name": "Alarm Pro",
    "slug": "alarm-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "alarmpro",
    "userInterfaceStyle": "dark",

    "icon": "./assets/icon.png",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1A"
    },

    "assetBundlePatterns": [
      "**/*"
    ],

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alarmpro.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch",
          "processing"
        ]
      }
    },

    "android": {
      "package": "com.alarmpro.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E1A"
      },
      "permissions": [
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "USE_EXACT_ALARM",
        "SCHEDULE_EXACT_ALARM"
      ]
    },

    "plugins": [
      "expo-notifications"
    ],

    "extra": {
      "eas": {
        "projectId": "auto"
      }
    },

    "updates": {
      "fallbackToCacheTimeout": 0
    },

    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}